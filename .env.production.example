# Core runtime
APP_ENV=production
LOG_LEVEL=INFO

# Gateway / Bridge
GRPC_TARGET=gateway:50051
BRIDGE_API_PORT=8080
CORS_ALLOW_ORIGINS=*
VITE_API_BASE_URL=http://localhost:8080

# ClickHouse root/admin (for migrator)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_admin
CLICKHOUSE_DB=neural_trader

# App-level ClickHouse credentials
CLICKHOUSE_APP_USER=nt_app
CLICKHOUSE_APP_PASSWORD=nt_app_password
CLICKHOUSE_READONLY_USER=nt_readonly
CLICKHOUSE_READONLY_PASSWORD=nt_readonly_password
